<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="50dp"
    android:layout_marginBottom="12dp"
    android:layout_gravity="center_horizontal|bottom"
    android:paddingHorizontal="26dp"
    android:gravity="center"
    android:background="@drawable/interactive_audio_bg"
    android:orientation="horizontal">
    <TextView
        android:id="@+id/tv_interaction_title"
        android:textColor="#2B2D42"
        android:textAlignment="textStart"
        android:textSize="14sp"
        tools:text="位置点选"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <View android:layout_marginHorizontal="16dp" android:layout_height="30dp" android:layout_width="1dp" android:background="#DEE3E8" />
    <TextView
        android:id="@+id/tv_audio_time"
        android:textColor="#2B2D42"
        android:textSize="14sp"
        tools:text="位置点选"
        android:layout_marginRight="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <ImageView
        android:id="@+id/ic_title"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/ic_play"
        />
</LinearLayout>