<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:paddingHorizontal="16dp"
    android:paddingVertical="5dp"
    android:background="#211F20"
    android:orientation="vertical">
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/ic_title"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_edit"
            />
        <TextView
            android:id="@+id/tv_interaction_title"
            android:textColor="@color/white"
            android:textAlignment="textStart"
            android:layout_weight="1"
            android:textSize="16sp"
            tools:text="位置点选"
            android:textStyle="bold"
            android:layout_marginLeft="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>
        <LinearLayout
            android:id="@+id/ll_result"
            tools:visibility="visible"
            android:visibility="gone"
            android:layout_marginVertical="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/ic_result"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_wrong"
                />
            <TextView
                android:id="@+id/tv_result_status"
                android:textColor="@color/superplayer_color_tint_red"
                android:layout_marginLeft="10dp"
                android:textSize="14sp"
                tools:text="错误"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tv_result_text"
                android:textColor="#ffE1E1E1"
                android:layout_marginLeft="15dp"
                android:textSize="14sp"
                tools:text="试试其他位置吧"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:id="@+id/tv_prompt"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:maxLines="5"
        tools:text="提交"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginVertical="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
    <EditText
        android:id="@+id/et_input"
        tools:hint="试试其他位置吧"
        android:paddingHorizontal="12dp"
        android:textColorHint="#E1E1E1"
        android:textSize="12sp"
        android:textColor="@color/white"
        android:background="@drawable/interactive_input_bg"
        android:inputType="text"
        android:singleLine="false"
        android:layout_weight="1"
        android:layout_marginRight="10dp"
        android:layout_width="0dp"
        android:layout_height="30dp"/>

    <LinearLayout
        android:id="@+id/ll_submit"
        android:background="@drawable/interactive_bg"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:layout_width="wrap_content"
        android:layout_height="30dp">
        <TextView
            android:id="@+id/tv_submit"
            android:textColor="@color/white"
            android:textSize="14sp"
            tools:text="提交"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    </LinearLayout>
</LinearLayout>