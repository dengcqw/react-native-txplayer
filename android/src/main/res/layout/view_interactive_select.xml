<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="match_parent"
    android:layout_gravity="right"
    android:paddingHorizontal="16dp"
    android:paddingVertical="20dp"
    android:background="#80000000"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical">
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/ic_title"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_hand_touch"
            />
        <TextView
            android:id="@+id/tv_interaction_title"
            android:textColor="@color/white"
            android:textAlignment="textStart"
            android:textSize="16sp"
            tools:text="位置点选"
            android:textStyle="bold"
            android:layout_marginLeft="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <TextView
        android:id="@+id/tv_prompt"
        android:textColor="#ffE1E1E1"
        android:textAlignment="textStart"
        android:layout_marginVertical="10dp"
        android:textSize="14sp"
        tools:text="请选择正确位置"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <ScrollView
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp">
        <LinearLayout
            android:id="@+id/ll_option_con"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="10dp"
                android:gravity="center|left"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/ic_select"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_unselect"
                    />
                <TextView
                    android:id="@+id/tv_title"
                    android:textColor="@color/white"
                    android:textAlignment="textStart"
                    android:textSize="16sp"
                    tools:text="位置点选"
                    android:textStyle="bold"
                    android:layout_marginLeft="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:tools="http://schemas.android.com/tools"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="10dp"
                android:gravity="center|left"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_unselect"
                    />
                <TextView
                    android:textColor="@color/white"
                    android:textAlignment="textStart"
                    android:textSize="16sp"
                    tools:text="位置点选"
                    android:textStyle="bold"
                    android:layout_marginLeft="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:tools="http://schemas.android.com/tools"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="10dp"
                android:gravity="center|left"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_unselect"
                    />
                <TextView
                    android:textColor="@color/white"
                    android:textAlignment="textStart"
                    android:textSize="16sp"
                    tools:text="位置点选"
                    android:textStyle="bold"
                    android:layout_marginLeft="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:id="@+id/ll_result"
        tools:visibility="visible"
        android:visibility="gone"
        android:layout_marginVertical="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/ic_result"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_wrong"
            />
        <TextView
            android:id="@+id/tv_result_status"
            android:textColor="@color/superplayer_color_tint_red"
            android:layout_marginLeft="10dp"
            android:textSize="14sp"
            tools:text="错误"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/tv_result_text"
            android:textColor="#ffE1E1E1"
            android:layout_marginLeft="15dp"
            android:textSize="14sp"
            tools:text="试试其他位置吧"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/ll_submit"
        android:background="@drawable/interactive_bg"
        android:layout_marginVertical="10dp"
        android:layout_marginRight="10dp"
        android:layout_gravity="right"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:layout_width="wrap_content"
        android:layout_height="30dp">
        <TextView
            android:id="@+id/tv_submit"
            android:textColor="@color/white"
            android:textSize="14sp"
            tools:text="提交"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>